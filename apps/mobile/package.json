{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.18.2",
    "@react-navigation/native": "^7.3.3",
    "@react-navigation/native-stack": "^7.17.6",
    "@vinyla/core-api": "*",
    "@vinyla/i18n": "*",
    "@vinyla/shared-types": "*",
    "@vinyla/ui": "*",
    "base64-arraybuffer": "^1.0.2",
    "expo": "^54.0.0",
    "expo-auth-session": "~7.0.11",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-file-system": "~19.0.23",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-localization": "~17.0.9",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-view-shot": "4.0.3"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "prebuild": "node -e \"const fs = require('fs'); if (!fs.existsSync('.env.local')) { console.warn('WARNING: .env.local is missing! Your EXPO_PUBLIC_* variables will not be injected. Build might fail at runtime.'); } else { console.log('✅ .env.local found. API keys will be injected.'); }\"",
    "build:ios": "npm run prebuild && eas build --platform ios --profile production --local",
    "build:android": "npm run prebuild && eas build --platform android --profile production --local",
    "build:all": "npm run prebuild && eas build --platform all --profile production"
  },
  "private": true
}
